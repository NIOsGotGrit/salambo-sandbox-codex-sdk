# Usually required for the default OpenAI/Codex provider
OPENAI_API_KEY=<SECRET>

# Optional - S2 StreamStore credentials for production event streaming
S2_ACCESS_TOKEN=your-s2-token
S2_BASIN=your-basin-name

# Optional - Server configuration
PORT=3000
WORKSPACE_DIR=/workspace
CODEX_MODEL=gpt-5.2-codex
CODEX_PROVIDER=openai

# Optional - S2 stream naming
S2_STREAM_PREFIX=agent-session

# Optional - local event buffer size when S2 is disabled
LOCAL_EVENT_MAX_EVENTS=500

# Optional - File sync gateway
GATEWAY_BASE_URL=

# Optional - Explicit path to codex or codex-app-server
SALAMBO_CODEX_PATH=

# Optional - Override the project-local Codex home (defaults to ./sandbox/codex-home)
CODEX_HOME=

# Optional - Provider-specific base URL
OPENAI_BASE_URL=

# Optional - File watcher stability (ms)
FILE_WATCH_STABILITY_MS=2000
